APP_NAME=Fraud Detection API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Fill these when ready to connect PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=Fraud_Detection_Database
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password

# Optional Redis cache
REDIS_URL=redis://localhost:6379/0

# Paths
DATA_DIR=./data
ARTIFACT_DIR=./artifacts
MODEL_DIR=./artifacts/models

# ML tracking
MLFLOW_TRACKING_URI=./artifacts/mlruns
WANDB_PROJECT=fraud-detection-dnn
WANDB_MODE=offline
